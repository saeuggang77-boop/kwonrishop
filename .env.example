# Database
DATABASE_URL="postgresql://username:password@localhost:5432/kwonrishop?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-random-secret-in-production"

# Kakao OAuth
KAKAO_CLIENT_ID="your-kakao-client-id"
KAKAO_CLIENT_SECRET="your-kakao-client-secret"

# Naver OAuth
NAVER_CLIENT_ID="your-naver-client-id"
NAVER_CLIENT_SECRET="your-naver-client-secret"

# Kakao Address API
NEXT_PUBLIC_KAKAO_JS_KEY="your-kakao-javascript-key"

# 국세청 사업자인증 API
NTS_API_KEY="your-nts-api-key"

# 공정거래위원회 API
FTC_API_KEY="your-ftc-api-key"

# Toss Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY="your-toss-client-key"
TOSS_SECRET_KEY="your-toss-secret-key"

# Cron Jobs
CRON_SECRET="your-cron-secret-for-vercel"

# S3 Storage (AWS S3 / Cloudflare R2 / MinIO)
# AWS S3를 사용하는 경우 S3_ENDPOINT는 비워두고, R2/MinIO는 설정하세요
S3_REGION="ap-northeast-2"
S3_ENDPOINT=""
S3_ACCESS_KEY_ID="your-s3-access-key-id"
S3_SECRET_ACCESS_KEY="your-s3-secret-access-key"
S3_BUCKET_NAME="kwonrishop-uploads"
S3_PUBLIC_URL=""

# Sentry
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Pusher (Real-time Chat)
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap3"

# Resend (Email)
RESEND_API_KEY=""
EMAIL_FROM="권리샵 <noreply@kwonrishop.com>"
