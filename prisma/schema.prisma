generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// 사용자 & 인증
// ==========================================

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  phone         String?
  image         String?
  password      String?
  role          UserRole  @default(BUYER)
  pendingRole   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  roleSelectedAt DateTime?

  accounts             Account[]
  sessions             Session[]
  businessVerification BusinessVerification?
  listing              Listing?
  franchiseBrand       FranchiseBrand?
  partnerService       PartnerService?
  equipment            Equipment[]
  equipmentFavorites   EquipmentFavorite[]
  chatParticipants     ChatParticipant[]
  messages             Message[]
  posts                Post[]
  comments             Comment[]
  reviews              Review[]
  favorites            Favorite[]
  notifications        Notification[]
  pushTokens           PushToken[]
  adPurchases          AdPurchase[]
  bumpSubscriptions    BumpSubscription[]
  reportsMade          Report[]  @relation("reporter")
  sellerReports        SellerReport[]
  franchiseInquiries   FranchiseInquiry[] @relation("UserFranchiseInquiries")
}

enum UserRole {
  BUYER
  SELLER
  FRANCHISE
  PARTNER
  ADMIN
}

// NextAuth 표준 모델
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// 사업자인증
// ==========================================

model BusinessVerification {
  id                 String    @id @default(cuid())
  userId             String    @unique
  businessNumber     String    @unique
  representativeName String
  openDate           String
  businessName       String?
  verified           Boolean   @default(false)
  verifiedAt         DateTime?
  createdAt          DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==========================================
// 업종 카테고리
// ==========================================

model Category {
  id        String @id @default(cuid())
  name      String @unique
  icon      String?
  sortOrder Int    @default(0)

  subCategories SubCategory[]
  listings      Listing[]
}

model SubCategory {
  id         String @id @default(cuid())
  name       String
  icon       String?
  sortOrder  Int    @default(0)
  categoryId String

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  listings Listing[]

  @@unique([categoryId, name])
}

// ==========================================
// 매물 (핵심)
// ==========================================

model Listing {
  id     String        @id @default(cuid())
  userId String        @unique // 1인 1매물
  status ListingStatus @default(DRAFT)

  // Step 1: 위치정보
  zipCode       String?
  addressJibun  String?
  addressRoad   String?
  addressDetail String?
  latitude      Float?
  longitude     Float?

  // Step 2: 업종 + 금액
  categoryId          String?
  subCategoryId       String?
  deposit             Int       @default(0)
  monthlyRent         Int       @default(0)
  premium             Int       @default(0)
  premiumNone         Boolean   @default(false)
  premiumNegotiable   Boolean   @default(false)
  premiumBusiness     Int?
  premiumBusinessDesc String?   @db.Text
  premiumFacility     Int?
  premiumFacilityDesc String?   @db.Text
  premiumLocation     Int?
  premiumLocationDesc String?   @db.Text
  maintenanceFee      Int?

  // Step 3: 기본정보
  brandType      BrandType @default(PRIVATE)
  storeName      String?
  currentFloor   Int?
  totalFloor     Int?
  isBasement     Boolean   @default(false)
  areaPyeong     Float?
  areaSqm        Float?
  themes         String[]
  parkingTotal   Int?
  parkingPerUnit Int?
  parkingNone    Boolean   @default(false)

  // Step 4: 추가정보
  monthlyRevenue     Int?
  expenseMaterial    Int?
  expenseLabor       Int?
  operationType      OperationType @default(SOLO)
  familyWorkers      Int?
  employeesFull      Int?
  employeesPart      Int?
  expenseRent        Int?
  expenseMaintenance Int?
  expenseUtility     Int?
  expenseOther       Int?
  monthlyProfit      Int?
  profitDescription  String?       @db.Text

  // Step 5: 매물설명
  description String? @db.Text

  // Step 6: 연락처
  contactPublic Boolean @default(false)

  // 메타
  viewCount     Int       @default(0)
  favoriteCount Int       @default(0)
  bumpedAt      DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category?            @relation(fields: [categoryId], references: [id])
  subCategory  SubCategory?         @relation(fields: [subCategoryId], references: [id])
  images       ListingImage[]
  documents    ListingDocument[]
  favorites         Favorite[]
  chatRooms         ChatRoom[]
  adPurchases       AdPurchase[]
  bumpSubscriptions BumpSubscription[]
  reviews           Review[]
  externalData      ListingExternalData?
  priceHistory PriceHistory[]
  sellerReports     SellerReport[]

  @@index([categoryId, subCategoryId])
  @@index([status, bumpedAt])
  @@index([status, createdAt])
  @@index([latitude, longitude])
}

enum ListingStatus {
  DRAFT
  ACTIVE
  RESERVED
  SOLD
  EXPIRED
  DELETED
}

enum BrandType {
  FRANCHISE
  PRIVATE
}

enum OperationType {
  SOLO
  FAMILY
  EMPLOYEE
}

// ==========================================
// 매물 이미지 & 문서
// ==========================================

model ListingImage {
  id        String    @id @default(cuid())
  listingId String
  url       String
  type      ImageType @default(OTHER)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

enum ImageType {
  EXTERIOR
  INTERIOR
  KITCHEN
  OTHER
}

model ListingDocument {
  id        String   @id @default(cuid())
  listingId String
  url       String
  type      DocType  @default(REVENUE_PROOF)
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

enum DocType {
  REVENUE_PROOF
}

// ==========================================
// 외부 연동 데이터
// ==========================================

model ListingExternalData {
  id        String   @id @default(cuid())
  listingId String   @unique
  hometax   Json?
  creditCard Json?
  baemin    Json?
  yogiyo    Json?
  coupang   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

// ==========================================
// 프랜차이즈
// ==========================================

model FranchiseBrand {
  id             String @id @default(cuid())
  managerId      String? @unique

  // 공정위 API 기본 데이터
  ftcId          String? @unique
  brandName      String
  companyName    String
  businessNumber String? @unique
  industry       String?
  franchiseFee   Int?
  educationFee   Int?
  depositFee     Int?
  royalty        String?
  totalStores    Int?
  avgRevenue     Int?
  ftcRegisteredAt String?
  ftcRawData     Json?

  // 유료 서비스 - 본사가 직접 편집
  tier           FranchiseTier @default(FREE)
  logo           String?
  bannerImage    String?
  description    String?       @db.Text
  benefits       String?       @db.Text
  contactPhone   String?
  contactEmail   String?
  website        String?

  tierExpiresAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manager   User?              @relation(fields: [managerId], references: [id])
  inquiries FranchiseInquiry[]

  @@index([industry])
  @@index([brandName])
}

enum FranchiseTier {
  FREE
  BRONZE
  SILVER
  GOLD
}

model FranchiseInquiry {
  id        String   @id @default(cuid())
  brandId   String
  userId    String?
  name      String
  phone     String
  message   String?  @db.Text
  createdAt DateTime @default(now())

  brand FranchiseBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  user  User?          @relation("UserFranchiseInquiries", fields: [userId], references: [id])
}

// ==========================================
// 협력업체 서비스
// ==========================================

model PartnerService {
  id          String              @id @default(cuid())
  userId      String              @unique  // 1업체 1등록
  status      ListingStatus       @default(DRAFT)

  companyName   String
  serviceType   PartnerServiceType
  description   String?           @db.Text
  contactPhone  String?
  contactEmail  String?
  website       String?

  addressRoad   String?
  addressJibun  String?
  addressDetail String?
  latitude      Float?
  longitude     Float?
  serviceArea   String[]

  tier          PartnerTier       @default(FREE)
  tierExpiresAt DateTime?

  viewCount     Int               @default(0)
  favoriteCount Int               @default(0)
  bumpedAt      DateTime?
  expiresAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  user          User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  images        PartnerImage[]
  adPurchases   AdPurchase[]

  @@index([serviceType])
  @@index([status, bumpedAt])
  @@index([status, createdAt])
  @@index([latitude, longitude])
}

enum PartnerServiceType {
  INTERIOR
  SIGNAGE
  EQUIPMENT
  CLEANING
  ACCOUNTING
  LEGAL
  POS_SYSTEM
  DELIVERY
  MARKETING
  CONSULTING
  OTHER
}

enum PartnerTier {
  FREE
  BASIC
  PREMIUM
  VIP
}

model PartnerImage {
  id               String         @id @default(cuid())
  partnerServiceId String
  url              String
  type             ImageType      @default(OTHER)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())

  partnerService PartnerService @relation(fields: [partnerServiceId], references: [id], onDelete: Cascade)
}

// ==========================================
// 광고 상품 & 결제
// ==========================================

model AdProduct {
  id            String          @id @default(cuid())
  name          String
  type          AdType
  categoryScope AdCategoryScope @default(LISTING)
  price         Int
  duration      Int?
  features      Json
  active        Boolean         @default(true)
  sortOrder     Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  purchases AdPurchase[]
}

enum AdType {
  PACKAGE
  SINGLE
  SUBSCRIPTION
}

enum AdCategoryScope {
  LISTING
  FRANCHISE
  PARTNER
  COMMON
  EQUIPMENT
}

model AdPurchase {
  id               String        @id @default(cuid())
  userId           String
  listingId        String?
  partnerServiceId String?
  equipmentId      String?
  productId        String
  status           PaymentStatus @default(PENDING)
  amount           Int
  paymentKey       String?
  activatedAt        DateTime?
  expiresAt          DateTime?
  viewCountAtAdStart Int?
  bumpUsedCount      Int           @default(0)
  createdAt          DateTime      @default(now())

  user             User              @relation(fields: [userId], references: [id])
  listing          Listing?          @relation(fields: [listingId], references: [id])
  partnerService   PartnerService?   @relation(fields: [partnerServiceId], references: [id])
  equipment        Equipment?        @relation(fields: [equipmentId], references: [id])
  product          AdProduct         @relation(fields: [productId], references: [id])
  bumpSubscription BumpSubscription?
  sellerReport     SellerReport?

  @@index([userId, status])
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
  EXPIRED
}

model BumpSubscription {
  id          String                 @id @default(cuid())
  userId      String
  listingId   String?
  equipmentId String?

  frequency  BumpFrequency
  bumpTimes  String[] // ["09:00", "18:00"] 형태
  nextBumpAt DateTime

  adPurchaseId String                  @unique
  status       BumpSubscriptionStatus @default(ACTIVE)

  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  cancelledAt DateTime?

  user       User        @relation(fields: [userId], references: [id])
  listing    Listing?    @relation(fields: [listingId], references: [id])
  equipment  Equipment?  @relation(fields: [equipmentId], references: [id])
  adPurchase AdPurchase  @relation(fields: [adPurchaseId], references: [id])

  @@index([status, nextBumpAt])
  @@index([userId])
}

enum BumpFrequency {
  TWICE_WEEKLY  // 주 2회 (월, 목)
  WEEKDAY_DAILY // 주 5회 (평일 매일)
  DAILY         // 매일 1회
  TWICE_DAILY   // 매일 2회
}

enum BumpSubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
}

// ==========================================
// 채팅
// ==========================================

model ChatRoom {
  id          String   @id @default(cuid())
  listingId   String?
  equipmentId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  listing      Listing?          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  equipment    Equipment?        @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages     Message[]
}

model ChatParticipant {
  id         String    @id @default(cuid())
  chatRoomId String
  userId     String
  lastReadAt DateTime?

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@unique([chatRoomId, userId])
}

model Message {
  id         String   @id @default(cuid())
  chatRoomId String
  senderId   String
  content    String   @db.Text
  createdAt  DateTime @default(now())

  chatRoom ChatRoom @relation(fields: [chatRoomId], references: [id], onDelete: Cascade)
  sender   User     @relation(fields: [senderId], references: [id])

  @@index([chatRoomId, createdAt])
}

// ==========================================
// 커뮤니티 (자유게시판)
// ==========================================

model Post {
  id        String   @id @default(cuid())
  authorId  String
  title     String
  content   String   @db.Text
  tag       String?
  viewCount Int      @default(0)
  likeCount Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  author   User      @relation(fields: [authorId], references: [id])
  comments Comment[]

  @@index([tag, createdAt])
  @@index([createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  content   String   @db.Text
  createdAt DateTime @default(now())

  post    Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User      @relation(fields: [authorId], references: [id])
  parent  Comment?  @relation("replies", fields: [parentId], references: [id])
  replies Comment[] @relation("replies")
}

// ==========================================
// 관심매물 & 리뷰 & 알림 & 신고
// ==========================================

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Review {
  id                  String   @id @default(cuid())
  reviewerId          String
  listingId           String
  accuracyRating      Int
  communicationRating Int
  conditionRating     Int
  content             String?  @db.Text
  createdAt           DateTime @default(now())

  reviewer User    @relation(fields: [reviewerId], references: [id])
  listing  Listing @relation(fields: [listingId], references: [id])

  @@unique([reviewerId, listingId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  device    String   @default("web")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Report {
  id         String       @id @default(cuid())
  reporterId String
  targetId   String
  targetType String
  reason     String
  detail     String?      @db.Text
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())
  resolvedAt DateTime?

  reporter User @relation("reporter", fields: [reporterId], references: [id])
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ==========================================
// 고객센터 문의
// ==========================================

model ContactInquiry {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String        @db.Text
  status    InquiryStatus @default(PENDING)
  adminNote String?       @db.Text
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([status, createdAt])
}

enum InquiryStatus {
  PENDING
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ==========================================
// 집기장터
// ==========================================

enum EquipmentCondition {
  EXCELLENT  // 상
  GOOD       // 중
  FAIR       // 하
}

enum TradeMethod {
  DIRECT     // 직거래
  DELIVERY   // 택배
  BOTH       // 둘 다
}

enum EquipmentCategory {
  KITCHEN        // 주방기기
  REFRIGERATION  // 냉장/냉동
  TABLE_CHAIR    // 테이블/의자
  DISPLAY        // 진열장/쇼케이스
  COOKING_TOOL   // 조리도구
  POS_ELECTRONIC // POS/전자기기
  SIGN           // 간판/사인물
  INTERIOR       // 인테리어 소품
  OTHER          // 기타
}

model Equipment {
  id          String             @id @default(cuid())
  userId      String
  status      ListingStatus      @default(DRAFT)

  // 기본 정보
  title       String
  description String             @db.Text
  category    EquipmentCategory
  condition   EquipmentCondition

  // 가격
  price       Int                // 0 = 무료 나눔
  negotiable  Boolean            @default(false)

  // 거래
  tradeMethod TradeMethod        @default(DIRECT)

  // 위치 (직거래용)
  addressRoad   String?
  addressJibun  String?
  addressDetail String?
  latitude      Float?
  longitude     Float?

  // 상세
  brand         String?
  modelName     String?
  purchaseYear  Int?
  quantity      Int              @default(1)

  // 등급 (협력업체와 동일 구조)
  tier          PartnerTier       @default(FREE)
  tierExpiresAt DateTime?

  // 카운터
  viewCount     Int              @default(0)
  favoriteCount Int              @default(0)
  bumpedAt      DateTime?
  expiresAt     DateTime?

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  // 관계
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  images        EquipmentImage[]
  favorites         EquipmentFavorite[]
  chatRooms         ChatRoom[]
  adPurchases       AdPurchase[]
  bumpSubscriptions BumpSubscription[]

  @@index([category])
  @@index([status, bumpedAt])
  @@index([status, createdAt])
  @@index([userId])
  @@index([latitude, longitude])
}

model EquipmentImage {
  id          String    @id @default(cuid())
  equipmentId String
  url         String
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())

  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@index([equipmentId])
}

model EquipmentFavorite {
  id          String    @id @default(cuid())
  userId      String
  equipmentId String
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@unique([userId, equipmentId])
}

// ==========================================
// 가격 변동 이력
// ==========================================

model PriceHistory {
  id        String   @id @default(cuid())
  listingId String
  field     String   // "deposit", "monthlyRent", "premium"
  oldValue  Int
  newValue  Int
  createdAt DateTime @default(now())

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, createdAt])
}

// ==========================================
// 매도자 시장분석 리포트
// ==========================================

model SellerReport {
  id          String   @id @default(cuid())
  userId      String
  listingId   String

  reportData  Json     // 분석 결과 전체 JSON

  adPurchaseId String  @unique

  createdAt   DateTime @default(now())

  user        User       @relation(fields: [userId], references: [id])
  listing     Listing    @relation(fields: [listingId], references: [id])
  adPurchase  AdPurchase @relation(fields: [adPurchaseId], references: [id])

  @@index([userId])
  @@index([listingId])
}
