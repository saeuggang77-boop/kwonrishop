{
  "buildCommand": "npx prisma generate && npm run build",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/expire-listings",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/expire-ads",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/sync-franchise",
      "schedule": "0 4 1 * *"
    },
    {
      "path": "/api/cron/auto-bump",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/cleanup-pending",
      "schedule": "30 * * * *"
    },
    {
      "path": "/api/cron/cleanup-orphan-images",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sync-franchise-disclosure",
      "schedule": "0 5 * * 1"
    }
  ]
}
